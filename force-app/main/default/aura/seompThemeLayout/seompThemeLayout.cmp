<aura:component implements="forceCommunity:themeLayout" access="global" description="SentinelFlow Custom Theme Layout">
    <aura:attribute name="body" type="Aura.Component[]"/>
    
    <div class="sentinelflow-theme">
        <div class="app-shell">
            <c:seompThemeHeader />
            <div class="layout-body">
                <c:seompThemeSidebar />
                <div class="main-content">
                    {!v.body}
                </div>
            </div>
        </div>
    </div>
</aura:component>
